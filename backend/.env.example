# ─────────────────────────────────────────────
# SmartProgress — Backend Environment Variables
# ─────────────────────────────────────────────
# Bu dosyayı .env olarak kopyalayıp değerleri güncelleyiniz.

NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://smartprogress:smartprogress_secret@localhost:5432/smartprogress_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (sonraki aşamada kullanılacak)
# JWT_SECRET=your-super-secret-jwt-key
# JWT_EXPIRES_IN=180d

# Password reset
APP_URL=https://app.smartprogress.online
PASSWORD_RESET_EXPIRES_MINUTES=60
# PASSWORD_RESET_FROM_EMAIL=SmartProgress <noreply@smartprogress.online>
# RESEND_API_KEY=
# BREVO_API_KEY=

# AI provider (mock keeps AI endpoints budget-safe without external calls)
AI_PROVIDER=mock
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_INPUT_COST_MICROS_PER_1K=1000
AI_OUTPUT_COST_MICROS_PER_1K=4000
AI_DEFAULT_MAX_OUTPUT_TOKENS=500
