// ─────────────────────────────────────────────────────────────
// SmartProgress — Prisma Schema
// Layered Architecture + Outbox Pattern
// PostgreSQL with JSONB support for flexible workout logging
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// User — Sporcu profili
// ─────────────────────────────────────────────
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  nickname     String?  @map("nickname")
  avatarUrl    String?  @map("avatar_url")
  settings     Json?    @db.JsonB
  subscriptionTier   SubscriptionTier   @default(FREE) @map("subscription_tier")
  subscriptionStatus SubscriptionStatus @default(INACTIVE) @map("subscription_status")
  passwordResetTokenHash String?   @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  role         Role     @default(ATHLETE)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workoutLogs WorkoutLog[]
  programs    Program[]
  programStars ProgramStar[]
  bodyMeasurements BodyMeasurement[]
  nutritionLogs NutritionLog[]
  notifications Notification[]
  aiUsageEvents AiUsageEvent[]
  coachWeeklyReports CoachWeeklyReport[]
  coachAiMessages CoachAiMessage[]
  coachInsights CoachInsight[]

  @@map("users")
}

model CoachWeeklyReport {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  weekStart  DateTime @map("week_start") @db.Date
  sourceHash String?  @map("source_hash")
  status     String   @default("ready")
  data       Json     @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
  @@map("coach_weekly_reports")
}

model AiUsageEvent {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  feature             String
  provider            String?
  model               String?
  inputTokens         Int      @default(0) @map("input_tokens")
  outputTokens        Int      @default(0) @map("output_tokens")
  estimatedCostMicros Int      @default(0) @map("estimated_cost_micros")
  metadata            Json?    @db.JsonB
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature])
  @@map("ai_usage_events")
}

model CoachAiMessage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  question  String
  answer    String
  source    String
  reason    String?
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("coach_ai_messages")
}

model CoachInsight {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  type         String
  exerciseName String  @map("exercise_name")
  decision     String
  reason       String
  flags        Json?   @db.JsonB
  currentBest  Json?   @map("current_best") @db.JsonB
  previousBest Json?   @map("previous_best") @db.JsonB
  sourceLogId  String  @map("source_log_id") @db.Uuid
  signalDate   DateTime @map("signal_date") @db.Date
  weekStart    DateTime @map("week_start") @db.Date
  metadata     Json?   @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, exerciseName, sourceLogId])
  @@index([userId, signalDate])
  @@index([userId, type])
  @@map("coach_insights")
}

model Notification {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  type         String
  title        String
  message      String
  actionLabel  String?   @map("action_label")
  actionScreen String?   @map("action_screen")
  actionParams Json?     @map("action_params") @db.JsonB
  metadata     Json?     @db.JsonB
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model BodyMeasurement {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @db.Date
  weight    Float?
  waist     Float?
  chest     Float?
  arm       Float?
  leg       Float?
  hip       Float?
  shoulder  Float?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
  @@map("body_measurements")
}

model NutritionLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @db.Date
  calories  Int?
  protein   Float?
  carbs     Float?
  fat       Float?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
  @@map("nutrition_logs")
}

enum Role {
  ATHLETE
  COACH
  ADMIN
}

enum SubscriptionTier {
  FREE
  PRO
  COACH_PLUS
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIAL
}

// ─────────────────────────────────────────────
// Sport — Spor dalı tanımı
// ─────────────────────────────────────────────
model Sport {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  icon      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workoutLogs WorkoutLog[]

  @@map("sports")
}

// ─────────────────────────────────────────────
// Program — Antrenman programı
// ─────────────────────────────────────────────
model Program {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String
  description     String?
  data            Json?    @db.JsonB
  isPublic        Boolean  @default(false) @map("is_public")
  sourceProgramId String?  @map("source_program_id") @db.Uuid
  // ── Cycle-Based Fields ─────────────────────
  frequency       Int      @default(7) @map("frequency")          // sessions per week
  currentDayIndex Int      @default(0) @map("current_day_index")  // which day is next
  starCount       Int      @default(0) @map("star_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  programStars ProgramStar[]

  @@index([userId])
  @@index([isPublic])
  @@index([sourceProgramId])
  @@index([starCount])
  @@map("programs")
}

model ProgramStar {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  programId String   @map("program_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([programId])
  @@index([userId])
  @@map("program_stars")
}

// ─────────────────────────────────────────────
// WorkoutLog — Antrenman kaydı (JSONB)
// ─────────────────────────────────────────────
// `data` alanı PostgreSQL JSONB formatında saklanır.
// Farklı spor dallarına özel esnek log yapısı:
//
// Örnek — Fitness:
// {
//   "exercises": [
//     {
//       "name": "Bench Press",
//       "sets": [
//         { "reps": 10, "weight": 80, "unit": "kg" },
//         { "reps": 8,  "weight": 85, "unit": "kg" }
//       ]
//     }
//   ],
//   "totalDuration": 3600,
//   "caloriesBurned": 450
// }
//
// Örnek — Koşu:
// {
//   "distance": 10.5,
//   "distanceUnit": "km",
//   "duration": 3150,
//   "avgPace": "5:00",
//   "avgHeartRate": 155,
//   "elevationGain": 120,
//   "route": { "type": "LineString", "coordinates": [...] }
// }
//
model WorkoutLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  sportId   String   @map("sport_id") @db.Uuid
  title     String
  notes     String?
  data      Json     @db.JsonB
  logDate   DateTime @map("log_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport Sport @relation(fields: [sportId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([sportId])
  @@index([logDate])
  @@index([userId, logDate])
  @@map("workout_logs")
}

// ─────────────────────────────────────────────
// OutboxEvent — Outbox Pattern
// ─────────────────────────────────────────────
// Event'lerin veritabanı transaction'ı ile birlikte
// güvenli bir şekilde kaydedilip, ayrı bir process
// tarafından asenkron olarak yayınlanmasını sağlar.
//
// Akış:
// 1. İş mantığı + OutboxEvent aynı transaction'da yazılır
// 2. Background job (outbox processor) processedAt=null olan
//    event'leri okur, yayınlar, processedAt'i günceller
//
model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id") @db.Uuid
  eventType     String    @map("event_type")
  payload       Json      @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at")
  processedAt   DateTime? @map("processed_at")

  @@index([processedAt])
  @@index([aggregateType, aggregateId])
  @@index([createdAt])
  @@map("outbox_events")
}
