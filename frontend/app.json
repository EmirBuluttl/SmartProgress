{
  "expo": {
    "name": "SmartProgress",
    "slug": "smartprogress",
    "version": "1.0.1",
    "scheme": [
      "smartprogress",
      "com.smartprogress.app"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartprogress.app",
      "buildNumber": "10",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Profil fotoğrafı çekmek için kamera erişimi kullanılır.",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafı seçmek için fotoğraf galerisi erişimi kullanılır.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 39,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "package": "com.smartprogress.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "a6d4fcd6-fdc0-45c7-ac56-0e0072772783"
      }
    },
    "owner": "bruhsound",
    "plugins": [
      "expo-notifications",
      "expo-web-browser"
    ]
  }
}
