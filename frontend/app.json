{
    "expo": {
        "name": "SmartProgress",
        "slug": "smartprogress",
        "version": "1.0.0",
        "scheme": "smartprogress",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#1a1a2e"
        },
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.smartprogress.app",
            "buildNumber": "1",
            "infoPlist": {
                "NSCameraUsageDescription": "Profil fotoğrafı çekmek için kamera erişimi kullanılır.",
                "NSPhotoLibraryUsageDescription": "Profil fotoğrafı seçmek için fotoğraf galerisi erişimi kullanılır."
            }
        },
        "android": {
            "versionCode": 1,
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#1a1a2e"
            },
            "permissions": [
                "CAMERA",
                "READ_MEDIA_IMAGES"
            ],
            "package": "com.smartprogress.app"
        },
        "web": {
            "favicon": "./assets/favicon.png",
            "bundler": "metro"
        }
    }
}
