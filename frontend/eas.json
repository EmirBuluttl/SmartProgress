{
    "cli": {
        "version": ">= 12.0.0",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_API_URL": "https://api.smartprogress.online",
                "EXPO_PUBLIC_REVENUECAT_PREMIUM_ENTITLEMENT_ID": "premium"
            }
        },
        "preview": {
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_API_URL": "https://api.smartprogress.online",
                "EXPO_PUBLIC_REVENUECAT_PREMIUM_ENTITLEMENT_ID": "premium"
            }
        },
        "production": {
            "autoIncrement": true,
            "environment": "production",
            "env": {
                "EXPO_PUBLIC_API_URL": "https://api.smartprogress.online",
                "EXPO_PUBLIC_REVENUECAT_PREMIUM_ENTITLEMENT_ID": "premium",
                "EXPO_PUBLIC_PRIVACY_URL": "https://app.smartprogress.online/privacy",
                "EXPO_PUBLIC_SUPPORT_URL": "https://app.smartprogress.online/support",
                "EXPO_PUBLIC_ACCOUNT_DELETION_URL": "https://app.smartprogress.online/account-deletion"
            }
        }
    },
    "submit": {
        "production": {}
    }
}
